---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kanban Game · Mis tableros">
  <div class="container">
    <div class="page-loading" id="loading"><span class="spinner"></span> Cargando…</div>
    <div id="content" hidden>
      <div class="flex-between">
        <h1>Mis partidas</h1>
        <div class="row" style="gap:8px">
          <a class="btn btn-sm" id="presentationLink" href="https://docs.google.com/presentation/d/1yBg-dKxUTUZg30WyiKdnDquwuPcX-9sn/present" target="_blank" rel="noopener" hidden>🖥️ Presentación</a>
          <a class="btn btn-sm" id="guiaLink" href="/guia" hidden>📋 Guía del debrief</a>
          <a class="btn btn-primary" id="adminLink" href="/admin" hidden>+ Administración</a>
        </div>
      </div>
      <div id="boards" class="grid grid-2" style="margin-top:16px"></div>
      <div id="empty" class="empty-state" hidden>
        <p>Todavía no estás en ninguna partida.</p>
        <p class="muted" id="emptyHint"></p>
      </div>
      <div id="rules" hidden style="margin-top:24px"></div>
    </div>
  </div>

  <style>
    #rules .rule-tabs { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 12px; }
    #rules .rule-panel { display: none; }
    #rules .rule-panel.active { display: block; }
    #rules ul { margin: 6px 0; padding-left: 20px; }
    #rules li { margin: 5px 0; }
    #rules ol { margin: 6px 0; padding-left: 22px; }
  </style>

  <script>
    import { requireAuth } from '../lib/session.js';
    import { watchBoards, watchTeams, watchPartidas } from '../lib/db.js';

    const { user, profile } = await requireAuth();
    const isAdmin = profile?.role === 'admin';
    document.getElementById('loading').remove();
    document.getElementById('content').hidden = false;
    if (isAdmin) {
      // Material de facilitador (debrief y presentación): solo admin.
      document.getElementById('adminLink').hidden = false;
      document.getElementById('guiaLink').hidden = false;
      document.getElementById('presentationLink').hidden = false;
    }

    let teams = {};
    let partidas = {};
    let boards = [];
    watchTeams((list) => { teams = Object.fromEntries(list.map((t) => [t.id, t])); render(); });
    watchPartidas((list) => { partidas = Object.fromEntries(list.map((p) => [p.id, p])); render(); });
    watchBoards((list) => { boards = list; render(); });

    function render() {
      const mine = boards.filter((b) => b.roleAssignments && b.roleAssignments[user.uid]);
      const host = document.getElementById('boards');
      const empty = document.getElementById('empty');

      const myRole = mine[0]?.roleAssignments?.[user.uid] || null;
      renderRules(myRole); // siempre, aunque no estés en ningún tablero (p.ej. admin)

      if (mine.length === 0) {
        host.innerHTML = '';
        empty.hidden = false;
        document.getElementById('emptyHint').textContent = isAdmin
          ? 'Crea equipos y asígnate (o usa Administración).'
          : 'El facilitador te incluirá en un equipo en breve.';
        return;
      }
      empty.hidden = true;

      // Una partida = el equipo del jugador con sus 2 tableros (sin/con WIP). Agrupar por equipo.
      const groups = {};
      for (const b of mine) {
        (groups[b.teamId] = groups[b.teamId] || []).push(b);
      }

      // Entrar automáticamente solo si tengo UNA partida en juego (una persona puede estar en
      // varias partidas). Si hay varias activas, NO autoentro: las muestro para que elija.
      const playingBoards = mine.filter((b) => b.status === 'playing');
      const activeTeams = new Set(playingBoards.map((b) => b.teamId));
      if (activeTeams.size === 1 && !sessionStorage.getItem('kbg.entered.' + playingBoards[0].id)) {
        sessionStorage.setItem('kbg.entered.' + playingBoards[0].id, '1');
        window.location.href = '/board?id=' + playingBoards[0].id;
        return;
      }

      host.innerHTML = Object.values(groups).map((bs) => {
        const team = teams[bs[0].teamId]?.name || 'Tu equipo';
        const partidaName = partidas[bs[0].partidaId]?.name || '';
        const role = bs[0].roleAssignments?.[user.uid];
        const active = bs.find((b) => b.status === 'playing');
        const finished = bs.filter((b) => b.status === 'finished');

        let state; let actions;
        if (active) {
          state = '<span class="tag" style="background:#1f3a2a;color:#9ff0c0">🟢 En juego</span>';
          actions = `<a class="btn btn-primary btn-lg" href="/board?id=${active.id}">▶ Entrar a la partida</a>`;
        } else if (finished.length === bs.length && bs.length > 0) {
          state = '<span class="tag">🏁 Terminada</span>';
          actions = `<a class="btn" href="/results?id=${bs[0].id}">📊 Ver resultados</a>`;
        } else {
          state = '<span class="tag" style="background:#3a3416;color:#ffe08a">⏳ En preparación</span>';
          actions = `<p class="muted" style="margin:0">Prepárate: el facilitador iniciará la partida cuando estéis todos. Entrarás al tablero automáticamente.</p>${finished.length ? `<a class="btn btn-sm" href="/results?id=${finished[0].id}">📊 Resultados</a>` : ''}`;
        }

        return `
          <div class="card stack">
            <div class="flex-between">
              <h2 style="margin:0">${escapeHtml(partidaName || team)}</h2>
              ${state}
            </div>
            <div class="row" style="gap:8px">
              <span class="tag">👥 ${escapeHtml(team)}</span>
              ${role ? `<span class="tag role-${role}">Tu rol: ${role}</span>` : ''}
            </div>
            <div class="row">${actions}</div>
          </div>`;
      }).join('');
    }

    function escapeHtml(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    let rulesDone = false;
    function renderRules(myRole) {
      if (rulesDone) return;
      rulesDone = true;
      const host = document.getElementById('rules');
      host.hidden = false;

      const panels = {
        general: `
          <h3>Cómo funciona</h3>
          <ul>
            <li>🎯 <strong>Objetivo:</strong> llevar el máximo de historias hasta <strong>Done</strong>.</li>
            <li>🗂️ Una partida son <strong>2 tableros</strong> del mismo equipo: primero <strong>sin límite WIP</strong> y luego <strong>con límite WIP</strong>. Al final se comparan.</li>
            <li>🎲 El <strong>dado</strong> decide cuánto avanza cada cosa. Entrarás al tablero cuando el facilitador inicie.</li>
            <li>⛔ Con WIP: si la columna destino está llena, la historia <strong>no entra</strong> aunque el dado sea alto.</li>
          </ul>
          <h3>Los 5 pasos de cada turno (en orden)</h3>
          <ol>
            <li>El <strong>PM</strong> mete 3 historias en <strong>Backlog</strong>.</li>
            <li>El <strong>PM</strong> tira 1 dado y mueve esa cantidad de <strong>Backlog → Refinement</strong>.</li>
            <li>Los <strong>Devs</strong> actúan (una acción por Dev).</li>
            <li><strong>QA</strong> prueba las historias.</li>
            <li>El <strong>PM</strong> valida: <strong>Validación PM → Done</strong> (cierra el turno).</li>
          </ol>`,
        PM: `
          <h3>Tu rol: PM (Product Manager)</h3>
          <ul>
            <li><strong>Paso 1:</strong> metes <strong>3 historias</strong> nuevas en Backlog.</li>
            <li><strong>Paso 2:</strong> tiras <strong>1 dado</strong> y mueves esa cantidad de <strong>Backlog → Refinement</strong>.</li>
            <li><strong>Paso 5:</strong> tiras <strong>1 dado</strong> y validas esa cantidad de <strong>Validación PM → Done</strong> (cierra el turno).</li>
          </ul>`,
        DEV: `
          <h3>Tu rol: DEV (Desarrollo)</h3>
          <ul>
            <li>En tu turno tiras <strong>1 dado</strong> por una historia:</li>
            <li>&nbsp;&nbsp;• <strong>3 o más</strong> → avanza a la siguiente columna (Refinement → Desarrollo → Revisión PR).</li>
            <li>&nbsp;&nbsp;• <strong>1 o 2</strong> → no avanza este turno.</li>
            <li><strong>Revisar PR:</strong> con 3+, pasa una historia de <strong>Revisión PR → QA</strong>.</li>
            <li>👥 <strong>Pair (historias de 8 o 13):</strong> para avanzarlas hace falta <strong>otro Dev libre</strong> (lo coge el sistema solo). Salen <strong>2 dados</strong> y avanza si la <strong>suma ≥ 5</strong>; gasta el turno de los dos.</li>
            <li>Una acción por Dev y turno.</li>
          </ul>`,
        QA: `
          <h3>Tu rol: QA</h3>
          <ul>
            <li>Pruebas historias de la columna <strong>QA</strong> (máx. <strong>2 tiradas</strong> por turno).</li>
            <li><strong>3 o más</strong> → pasa a <strong>Validación PM</strong>.</li>
            <li><strong>1 o 2</strong> → ¡<strong>bug</strong>! vuelve a <strong>Desarrollo</strong>.</li>
          </ul>`,
      };

      const tabs = [
        { id: 'general', label: '📖 Reglas generales' },
        { id: 'PM', label: '🧭 PM' },
        { id: 'DEV', label: '💻 DEV' },
        { id: 'QA', label: '🔎 QA' },
      ];
      const active = (myRole && panels[myRole]) ? myRole : 'general';

      host.innerHTML = `
        <details class="card" style="padding:0">
          <summary style="cursor:pointer; padding:14px 16px; font-weight:700; font-size:1.05rem">📖 Reglas del juego <span class="muted" style="font-weight:400">— despliega para verlas</span></summary>
          <div style="padding:0 16px 16px">
            <div class="rule-tabs">
              ${tabs.map((t) => `<button class="${t.id === active ? 'btn-primary' : ''}" data-tab="${t.id}">${t.label}</button>`).join('')}
            </div>
            ${tabs.map((t) => `<div class="rule-panel ${t.id === active ? 'active' : ''}" data-panel="${t.id}">${panels[t.id]}</div>`).join('')}
          </div>
        </details>`;

      host.querySelectorAll('[data-tab]').forEach((btn) => {
        btn.onclick = () => {
          const id = btn.getAttribute('data-tab');
          host.querySelectorAll('[data-tab]').forEach((b) => b.classList.toggle('btn-primary', b === btn));
          host.querySelectorAll('[data-panel]').forEach((p) => p.classList.toggle('active', p.getAttribute('data-panel') === id));
        };
      });
    }
  </script>
</Layout>
