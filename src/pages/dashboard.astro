---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kanban Game · Mis tableros">
  <div class="container">
    <div class="page-loading" id="loading"><span class="spinner"></span> Cargando…</div>
    <div id="content" hidden>
      <div class="flex-between">
        <h1>Mis tableros</h1>
        <a class="btn btn-primary" id="adminLink" href="/admin" hidden>+ Administración</a>
      </div>
      <div id="boards" class="grid grid-2" style="margin-top:16px"></div>
      <div id="empty" class="empty-state" hidden>
        <p>Todavía no tienes ningún tablero asignado.</p>
        <p class="muted" id="emptyHint"></p>
      </div>
    </div>
  </div>

  <script>
    import { requireAuth } from '../lib/session.js';
    import { watchBoards, watchTeams } from '../lib/db.js';

    const ROUND_LABEL = { 1: 'Ronda 1 · sin WIP', 2: 'Ronda 2 · con WIP' };
    const STATUS_LABEL = { setup: 'En preparación', playing: 'En juego', finished: 'Terminada' };

    const { user, profile } = await requireAuth();
    const isAdmin = profile.role === 'admin';
    document.getElementById('loading').hidden = true;
    document.getElementById('content').hidden = false;
    if (isAdmin) document.getElementById('adminLink').hidden = false;

    let teams = {};
    watchTeams((list) => {
      teams = Object.fromEntries(list.map((t) => [t.id, t]));
      render();
    });

    let boards = [];
    watchBoards((list) => { boards = list; render(); });

    function render() {
      const mine = boards.filter((b) => isAdmin || (b.roleAssignments && b.roleAssignments[user.uid]));
      const host = document.getElementById('boards');
      const empty = document.getElementById('empty');

      if (mine.length === 0) {
        host.innerHTML = '';
        empty.hidden = false;
        document.getElementById('emptyHint').textContent = isAdmin
          ? 'Crea equipos y tableros en Administración para empezar.'
          : 'Pide a tu administrador que te asigne a un tablero.';
        return;
      }
      empty.hidden = true;

      host.innerHTML = mine.map((b) => {
        const role = b.roleAssignments?.[user.uid];
        const team = teams[b.teamId]?.name || '—';
        const nCols = b.columns ? Object.keys(b.columns).length : 0;
        return `
          <div class="card stack">
            <div class="flex-between">
              <h2 style="margin:0">${escapeHtml(b.name)}</h2>
              <span class="tag">${STATUS_LABEL[b.status] || b.status || ''}</span>
            </div>
            <div class="row" style="gap:8px">
              <span class="tag">👥 ${escapeHtml(team)}</span>
              <span class="tag">🧩 ${nCols} columnas</span>
              <span class="tag">${ROUND_LABEL[b.round] || ''}</span>
              ${role ? `<span class="tag role-${role}">Tu rol: ${role}</span>` : (isAdmin ? '<span class="tag admin">admin</span>' : '')}
            </div>
            <div class="row">
              <a class="btn btn-primary" href="/board?id=${b.id}">▶ Jugar</a>
              <a class="btn" href="/results?id=${b.id}">📊 Resultados</a>
              ${isAdmin ? `<a class="btn btn-ghost" href="/admin?board=${b.id}">⚙ Configurar</a>` : ''}
            </div>
          </div>`;
      }).join('');
    }

    function escapeHtml(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }
  </script>
</Layout>
