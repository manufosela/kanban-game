---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kanban Game · Entrar" header={false}>
  <section class="login-wrap">
    <div class="login-card card">
      <div class="hero">
        <div class="hero-logo">🃏</div>
        <h1>Kanban Game</h1>
      </div>
      <button id="googleBtn" class="btn-primary btn-lg">
        <span style="margin-right:8px">🔑</span> Entrar con Google
      </button>
      <div id="pending" hidden>
        <p style="margin:0 0 6px">⏳ <strong>Acceso pendiente de aprobación</strong></p>
        <p class="muted">Tu cuenta no es del dominio autorizado. Un facilitador debe aceptarte antes de entrar; vuelve a iniciar sesión cuando te avisen.</p>
        <button id="logoutBtn" class="btn-sm">Cerrar sesión</button>
      </div>
      <p class="muted small" id="status"></p>
    </div>
  </section>

  <style>
    .login-wrap {
      min-height: 100vh; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 28px; padding: 24px;
    }
    .login-card { width: min(440px, 96vw); text-align: center; padding: 32px; }
    .hero-logo { font-size: 3rem; }
    .hero h1 { margin: 8px 0; font-size: 2.2rem; }
    .small { font-size: .85rem; margin-top: 12px; min-height: 1.2em; }
  </style>

  <script>
    import { watchSession, signInWithGoogle, signOutUser } from '../lib/session.js';
    import { toast } from '../lib/ui.js';

    const status = document.getElementById('status');
    const pendingBox = document.getElementById('pending');
    const googleBtn = document.getElementById('googleBtn');

    // Si ya hay sesión: si está activo → dashboard; si está pendiente → aviso de espera.
    const unsub = watchSession(({ user, profile }) => {
      if (!user) return;
      if (profile?.status === 'pending') {
        status.textContent = '';
        googleBtn.hidden = true;
        pendingBox.hidden = false;
        return;
      }
      unsub();
      window.location.replace('/dashboard');
    });

    document.getElementById('logoutBtn').addEventListener('click', async () => {
      await signOutUser();
      pendingBox.hidden = true;
      googleBtn.hidden = false;
    });

    document.getElementById('googleBtn').addEventListener('click', async () => {
      status.textContent = 'Abriendo Google…';
      try {
        await signInWithGoogle();
        status.textContent = 'Entrando…';
      } catch (err) {
        console.error(err);
        status.textContent = '';
        const code = err?.code || '';
        if (code === 'auth/operation-not-allowed') {
          toast('El proveedor Google no está habilitado todavía en Firebase Auth.', 'error', 6000);
        } else if (code === 'auth/popup-closed-by-user') {
          toast('Has cerrado la ventana de Google.', 'warning');
        } else {
          toast('No se pudo iniciar sesión: ' + (err?.message || code), 'error', 6000);
        }
      }
    });
  </script>
</Layout>
