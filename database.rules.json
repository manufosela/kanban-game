{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".validate": "newData.hasChildren(['name', 'email', 'role'])",
        "role": {
          ".validate": "newData.val() === 'admin' || newData.val() === 'player'"
        }
      }
    },

    "teams": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$teamId": {
        ".validate": "newData.hasChildren(['name'])",
        "members": {
          "$uid": {
            ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || (!data.exists() && newData.exists() && root.child('teams').child($teamId).child('facilitatorUid').val() === auth.uid))"
          }
        },
        "localNames": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('teams').child($teamId).child('facilitatorUid').val() === auth.uid)"
        },
        "facilitatorUid": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (!data.exists() && newData.val() === auth.uid))"
        }
      }
    },

    "boards": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$boardId": {
        ".validate": "newData.hasChildren(['name'])",
        "roleAssignments": {
          "$uid": {
            ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || (!data.exists() && newData.exists() && root.child('teams').child(root.child('boards').child($boardId).child('teamId').val()).child('facilitatorUid').val() === auth.uid))"
          }
        },
        "round": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('facilitators').child(auth.uid).val() === true)"
        },
        "status": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('facilitators').child(auth.uid).val() === true)"
        },
        "columns": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('facilitators').child(auth.uid).val() === true)"
        }
      }
    },

    "facilitators": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "partidas": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$pid": {
        ".validate": "newData.hasChildren(['name'])",
        "session": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('partidas').child($pid).child('facilitators').child(auth.uid).val() === true)"
        }
      }
    },

    "bots": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "games": {
      ".read": "auth != null",
      "$boardId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('facilitators').child(auth.uid).val() === true || root.child('boards').child($boardId).child('roleAssignments').child(auth.uid).exists())"
      }
    },

    "results": {
      ".read": "auth != null",
      "$boardId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('facilitators').child(auth.uid).val() === true || root.child('boards').child($boardId).child('roleAssignments').child(auth.uid).exists())"
      }
    },

    "session": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('facilitators').child(auth.uid).val() === true)"
    },

    "invitedUsers": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$key": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (data.exists() && data.child('email').val() === auth.token.email))"
      }
    }
  }
}
