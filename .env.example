# Configuración pública de Firebase (web). Estos valores NO son secretos.
# Copia este fichero a .env. El apiKey web de Firebase es público por diseño;
# la seguridad real la imponen las reglas de Realtime Database y Auth.
PUBLIC_FB_API_KEY=tu-api-key-web
PUBLIC_FB_AUTH_DOMAIN=kanban-game-a51ad.firebaseapp.com
PUBLIC_FB_DATABASE_URL=https://kanban-game-a51ad-default-rtdb.firebaseio.com
PUBLIC_FB_PROJECT_ID=kanban-game-a51ad
PUBLIC_FB_STORAGE_BUCKET=kanban-game-a51ad.firebasestorage.app
PUBLIC_FB_MESSAGING_SENDER_ID=1099363638010
PUBLIC_FB_APP_ID=1:1099363638010:web:d110822209720c612a8743

# Emails (separados por comas) que serán admin automáticamente al registrarse.
# Además, el PRIMER usuario que entre en una base de datos vacía será admin.
PUBLIC_ADMIN_EMAILS=tu-email@example.com
