# Configuración pública de Firebase (web). Copia este fichero a .env y rellénalo con tu config.
# El apiKey web de Firebase NO es secreto (va embebido en el cliente); la seguridad la imponen
# las reglas de Realtime Database y los dominios autorizados de Auth. Aun así, usa placeholders aquí.
PUBLIC_FB_API_KEY=tu-api-key-web
PUBLIC_FB_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
PUBLIC_FB_DATABASE_URL=https://tu-proyecto-default-rtdb.firebaseio.com
PUBLIC_FB_PROJECT_ID=tu-proyecto
PUBLIC_FB_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
PUBLIC_FB_MESSAGING_SENDER_ID=000000000000
PUBLIC_FB_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# Emails (separados por comas) que serán admin automáticamente al registrarse.
# Además, el PRIMER usuario que entre en una base de datos vacía será admin.
PUBLIC_ADMIN_EMAILS=tu-email@example.com
